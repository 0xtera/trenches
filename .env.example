TRENCHES_SOURCE=dexscreener
TRENCHES_MODE=scan
TRENCHES_SCAN_ONCE=true
TRENCHES_SCAN_INTERVAL_MS=15000
TRENCHES_FORWARD_TEST_CYCLES=3
# For PM2/daemon mode, use TRENCHES_SCAN_ONCE=false via ecosystem.config.cjs
TRENCHES_CANDIDATE_LIMIT=30
TRENCHES_OUTPUT_LIMIT=10

TRENCHES_BANKROLL_USD=100
TRENCHES_REALIZED_LOSS_USD=0
TRENCHES_MAX_LOSS_BPS=1000
TRENCHES_RISK_PER_TRADE_BPS=100
TRENCHES_MAX_POSITION_BPS=1000
TRENCHES_MAX_POSITION_USD=25
TRENCHES_STOP_LOSS_BPS=1500
TRENCHES_TAKE_PROFIT_BPS=3000
TRENCHES_TRAILING_STOP_BPS=1200
TRENCHES_MAX_LIQUIDITY_IMPACT_BPS=75

TRENCHES_MIN_MARKET_CAP_USD=5000
TRENCHES_MAX_MARKET_CAP_USD=250000
TRENCHES_MIN_LIQUIDITY_USD=3000
TRENCHES_MAX_LIQUIDITY_USD=200000
TRENCHES_MIN_M5_BUYS=12
TRENCHES_MIN_BUY_SELL_RATIO=1.15
TRENCHES_MIN_PAIR_AGE_MS=180000
TRENCHES_MAX_PAIR_AGE_MS=86400000

TRENCHES_MAX_TOP_HOLDER_PCT=15
TRENCHES_MAX_TOP10_HOLDER_PCT=45
TRENCHES_MAX_BUNDLER_RATE=0.3
TRENCHES_MAX_RAT_TRADER_RATE=0.3
TRENCHES_MAX_RUG_RATIO=0.3
TRENCHES_MAX_RUG_SCORE=6000
TRENCHES_USE_RUGCHECK=true
TRENCHES_ALLOW_DEX_ADS=false
TRENCHES_ALLOW_BOOSTED_TOKENS=false

TRACKED_WALLETS=
TRENCHES_TRACKER_FILE=
TRENCHES_TRACKER_SOURCE=file
TRENCHES_TRACKER_LIMIT=100
TRENCHES_PUBLIC_TRACKER_FILE=data/public-tracked-wallets.json
TRENCHES_MIN_TRACKED_WALLET_HITS=2
TRENCHES_MIN_TRACKED_WALLET_VALUE_USD=0

TRENCHES_REQUIRE_BELOW_REFERENCE=true
TRENCHES_MAX_M5_PRICE_CHANGE_PCT=8
TRENCHES_MAX_H1_PRICE_CHANGE_PCT=20
TRENCHES_MIN_REFERENCE_DISCOUNT_PCT=3

SOL_USD_PRICE=150
TRENCHES_PLATFORM_FEE_BPS=100
TRENCHES_PROTOCOL_FEE_BPS=25
TRENCHES_PRIORITY_FEE_SOL=0.0005
TRENCHES_NETWORK_FEE_SOL=0.00025
TRENCHES_MAX_HARD_FEE_BPS=250
TRENCHES_MAX_ROUND_TRIP_HARD_FEE_BPS=500
TRENCHES_SLIPPAGE_BPS=700
TRENCHES_MAX_SLIPPAGE_BPS=1200

TRENCHES_EXECUTE=false
TRENCHES_EXECUTOR=dry-run
TRENCHES_LIVE_RISK_ACK=
GMGN_CLI_BIN=npx
GMGN_CLI_ARGS_PREFIX=-y,gmgn-cli
GMGN_TRENCHES_TYPES=new_creation,near_completion,completed
GMGN_TRENCHES_PLATFORMS=
GMGN_LIVE_AUTH_CONFIG=
GMGN_API_KEY=
GMGN_PRIVATE_KEY=
GMGN_WALLET_ADDRESS=

TRENCHES_HISTORICAL_FILE=
TRENCHES_PAPER_STATE_FILE=.trenches-paper-state.json
